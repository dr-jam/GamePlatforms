function _init()
	--start things here!
end


function _update()
	handle_player_input()
end

function _draw()
function _draw()
 cls()

 -- keep player centered
 camera(x - 64, y - 64)

 -- draw the tilemap in world space
 map(0, 0, 0, 0, 128, 128)

 -- draw the player at world coordinates
 spr(1, x, y)

 -- reset camera if you want to draw fixed-screen ui afterward
 camera()
 
 print(x .. " " .. y)
end
	
end
-->8
function handle_player_input()
	local dx = 0
	local dy = 0
	if btn(⬆️) then
		dy -1
	end
	
	if btn(⬇️) then
	 dy = 1
	end
	
	if btn(➡️) then
	 dx = 1
	end
	
	if btn(⬅️) then
		dx = -1
	end
	
	impass(dx, dy)
	
	x += dx
	y += dy
end
-->8
