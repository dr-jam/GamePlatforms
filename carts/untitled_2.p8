pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--character variables
x=64
y=64
walk1 = 1
walk2 = 2


function _init()
	--start things here!
end


function _update()
	handle_player_input()
end

function _draw()
function _draw()
 cls()

 -- keep player centered
 camera(x - 64, y - 64)

 -- draw the tilemap in world space
 map(0, 0, 0, 0, 128, 128)

 -- draw the player at world coordinates
 spr(1, x, y)

 -- reset camera if you want to draw fixed-screen ui afterward
 camera()
 
 print(x .. " " .. y)
end
	
end
-->8
function handle_player_input()
	if btn(⬆️) then
		y = y - 1
	end
	
	if btn(⬇️) then
	 y = y + 1
	end
	
	if btn(➡️) then
	 x = x + 1
	end
	
	if btn(⬅️) then
		x = x - 1
	end
end
