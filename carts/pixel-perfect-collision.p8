pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- pixel-perfect collision demo

function _init()
 p={x=60,y=60,sp=1,w=8,h=8}
 target={x=80,y=80,sp=2,w=16,h=16}
 colliding=false
end

function _update()
 -- movement
 if (btn(⬅️)) p.x-=1
 if (btn(➡️)) p.x+=1
 if (btn(⬆️)) p.y-=1
 if (btn(⬇️)) p.y+=1
 
 colliding = check_pixel_collision(p, target)
end

function _draw()
 cls(9)
 print("hit: "..(colliding and "yes" or "no"),4,12,colliding and 12 or 6)
 
 -- draw target
 spr(target.sp,target.x,target.y, target.w/8, target.h/8)
 
 spr(p.sp,p.x,p.y,p.w/8,p.h/8)
end



-->8
--collision deteection

function check_pixel_collision(a, b)
 -- step 1: standard aabb check (optimization)
 if (a.x > b.x + b.w - 1 or
     a.x + a.w - 1 < b.x or
     a.y > b.y + b.h - 1 or
     a.y + a.h - 1 < b.y) then
     return false
 end

 -- step 2: find the overlap rectangle
 local x_start = max(a.x, b.x)
 local x_end = min(a.x + a.w - 1, b.x + b.w - 1)
 local y_start = max(a.y, b.y)
 local y_end = min(a.y + a.h - 1, b.y + b.h - 1)

 -- step 3: iterate through the overlap area
 for py = y_start, y_end do
  for px = x_start, x_end do
   
   -- get pixel color relative to spritesheet
   -- we calculate the pixel's position inside the sprite
   local p_pixel = sget((a.sp%16)*8 + (px-a.x), flr(a.sp/16)*8 + (py-a.y))
   local t_pixel = sget((b.sp%16)*8 + (px-b.x), flr(b.sp/16)*8 + (py-b.y))
   
   -- if both pixels are not transparent (color 0)
   if (p_pixel != 0 and t_pixel != 0) return true
  end
 end
 
 return false
end
