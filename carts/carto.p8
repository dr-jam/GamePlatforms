__lua__
x = 0
y = 0

function _update()
  if btnp(0) then
   x = x - 1 -- x -= 1
  end
  
  if btnp(1) then
   x = x + 1 -- x += 1
  end 
  
  if btnp(2) then
   y = y - 1
  end
  
  if btnp(3) then
   y = y + 1
  end
  
end

function _draw() 
 cls(0)
 map(x,y,10,10,16,8)
end
