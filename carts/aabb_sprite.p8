pico-8 cartridge // http://www.pico-8.com
version 34
__lua__
--basic aabb collision detection

function _init()
 p = {x=10, y=10, w=8, h=8, dx=0, dy=0, c=2}
 o = {x=60, y=80, w=16, h=10, c=3}
 hit = false
 bg_color = 12
end

function _update60()
	move_player()
 hit = collision_aabb(p, o)
end

function _draw()
	cls(bg_color)
	
	if hit then
		print("hit!!")
	 p.c = 13
	 o.c = 11
 else
 	p.c = 1
 	o.c = 3
 end
	

	rectfill(o.x, o.y, o.x+o.w, o.y+o.h, o.c)
	--rect(p.x, p.y, p.x+p.w, p.y+p.h, p.c)	
	spr(1, p.x, p.y)
		
end
-->8
function move_player()
	if (btn(⬅️)) p.dx-=1
	if (btn(➡️)) p.dx+=1
	if (btn(⬆️)) p.dy-=1
	if (btn(⬇️)) p.dy+=1
	
	p.x += p.dx
	p.y += p.dy
	
	p.dx,p.dy=0,0
end
-->8
function collision_aabb(a, b)
	local a_right_b = a.x > b.x+b.w
	local a_left_b = a.x+a.w < b.x
	local a_above_b = a.y+a.h < b.y
	local a_below_b = a.y > b.y+b.h
	
	return not(a_right_b or 
		a_left_b or 
		a_above_b or 
		a_below_b)
end
