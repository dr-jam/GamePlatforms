pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
player = {}
player.x = 3
player.y = 4
player.col = 4

function _update()
	if btn(⬆️) then
		player.y -= 1
	end
	if btn(⬇️) then
		player.y += 1
	end
	if btn(➡️) then 
		player.x += 1
	end
	if btn(⬅️) then
		player.x -= 1
	end
end 

function _draw ()
 cls(1)
	circ(player.x, player.y, 2, player.co)
end
