pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--how to load sprites from mutliple carts
--thanks to lazy devs


function _init()
	spr_sheet=1
	loc={0x00, 0x80, 0xa0, 0xc0, 0xe0}
	reload(0x8000, 0x0000, 0x2000, "game1/fish.p8")
	reload(0xa000, 0x0000, 0x2000, "game1/gamble.p8")
	reload(0xc000, 0x0000, 0x2000, "game1/hunted.p8")
	reload(0xe000, 0x0000, 0x2000, "game1/solitaire.p8")
end	


function _update()
	if btnp(➡️) then
		spr_sheet+=1
		if spr_sheet>#loc then 
			spr_sheet=1 
		end
		poke(0x5f54, loc[spr_sheet])
	end
end
	
function _draw()
	cls()
	spr(0,0,0,16,16)
end

