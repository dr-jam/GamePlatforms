pico-8 cartridge // http://www.pico-8.com
version 34
__lua__
games={}
games[1]="the dragon's lair"
games[2]="nathan and makai"
games[3]="austin and marilyn"
games[4]="wizkids"
games[5]="catventure"
games[6]="prison break"
games[7]="master of the kitchen"
games[8]="bunnicare"
games[9]="lactose run"
games[10]="8 bit matrix"

srand(42)

while #games > 0 do
	local gamename = rnd(games)
	del(games, gamename)
	print(gamename)
end


