pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
x=50
y=50
c=14
game_over = false


function _init()
 music(0)
end

function print_credits()
	print("director: 😐",0,0,1)
	print("producer: revolver")
	print("lead designer: miyamoto")
end


function _update()
	if btn(⬆️) then
	 y -= 1
	else
		y += 1
	end
	
--	if not btn(⬆️) then
--	 y = y + 1
--	end
	
	if btn(🅾️) and btn(❎) then
		c = c + 1
		game_over = true
	end
	
	if btn(❎) then
	 sfx(0)
	end
end

function _draw()
 cls(5)
 circ(x,y,5,c)
 map(0,0)
 if game_over then
		print_credits()
	end
end
