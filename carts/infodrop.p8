pico-8 cartridge // http://www.pico-8.com
version 34
__lua__
function _init()
    initial_x = 64
    initial_y = 64
    x = initial_x
    y = initial_y
end

function _update()
 if btn(⬅️) then
  direction = ⬅️
  x = x - 1
 end
    
 if btn(➡️) then
 	 x = x + 1
 end
    
    if btn(⬆️) then
        y = y - 1
    end
    
    if btn(⬇️) then
        y = y + 1
    end

 if btn(❎) then
     x = initial_x
     y = initial_y
 end

end

function _draw()
 cls(1)
 print(x .. ", " .. y, x+8, y+4, 12)
 if facing==⬅️ then
  --draw left-facing sprite
 end
    spr(1, x, y)
end
