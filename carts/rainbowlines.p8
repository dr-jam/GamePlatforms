pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

xfactor=2

function _update()
	if btn(⬅️) then
		xfactor += 0.1
	end
	if btn(➡️) then
		xfactor -= 0.1
	end
	
	if btn(❎) then
		fillp(0b0011001111001100)
	else
		fillp(0)
	end
	
	if btn(🅾️) then
		pal({[12]=9, [14]=8})
	else
	 pal()
	end
end

function _draw()
	cls()
	for i=0,127,0.5 do
		line(i*xfactor, 0, i, 127, i/16+8)
	end
	color(0)
	pset(120, 20)
	
	ovalfill(30,10, 3, 15)
end
