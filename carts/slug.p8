pico-8 cartridge // http://www.pico-8.com
version 34
__lua__
function _init()
	local initial_x = 64
	local initial_y = 64
	x = initial_x
	y = initial_y
end

function _update()
	if btn(0) //x axis
	then x = x - 1
	end

	if btn(1) //x axis
	then
	x = x + 1
	end
	
	if btn(2) //y axis 
	then y = y - 1
	end

	if btn(3) //y axis
	then y = y + 1
	end

end

music (0) //play background

function _draw()

cls(1)


	if btn(1) //rotating sprites
	then spr(1, x, y) //left

	
	elseif btn(2)
	then spr(2, x, y) //up
	
	elseif btn(3)
	then spr(3, x, y) //up

	elseif btn(0)
	then spr(4, x, y) //up
	
	else //default
	spr(1, x, y)
	end
	
	print(x)//check
	print(y)//check
	
	 
end
